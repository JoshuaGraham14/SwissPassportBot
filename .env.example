# Copy this file to .env and fill in the values.
#
# Use the secure session link from the appointment email here. This contains
# your token, so keep .env private.
SESSION_URL="https://www.ch-edoc-reservation.admin.ch/#/session?token=PASTE-YOUR-TOKEN-HERE&locale=en-GB"

# Optional but recommended: paste the calendar URL from the browser after
# clicking Reschedule. The bot uses SESSION_URL first, then this route.
CALENDAR_URL="https://www.ch-edoc-reservation.admin.ch/#/businesscase/9115002/appointment/10016116/calendar;locationId=345;dateFrom=2026-04-27"

# Telegram details from BotFather and your chat/user/group id.
TELEGRAM_BOT_TOKEN="123456:ABCDEF"
TELEGRAM_CHAT_ID="123456789"

# Check from today through the next 31 days.
LOOKAHEAD_DAYS=31

# Used by `python -m swiss_passport_bot run`.
CHECK_INTERVAL_SECONDS=3600

# Keep this true for scheduled runs. If the site shows "Web Page Blocked",
# try false with real Chrome visible on screen.
HEADLESS=true

# Leave blank to use Playwright's managed Chromium browser. If the site blocks
# managed/headless Chromium, try the real Chrome app path below.
# BROWSER_EXECUTABLE_PATH="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
BROWSER_EXECUTABLE_PATH=""

# Send Telegram messages when the checker itself errors.
ALERT_ON_ERRORS=true

# Watchdog sends Telegram if no live check has succeeded recently.
WATCHDOG_STALE_AFTER_SECONDS=7200
WATCHDOG_ALERT_INTERVAL_SECONDS=21600
